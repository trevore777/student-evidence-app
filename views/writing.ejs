<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= assignment.title %></title>

  <link rel="stylesheet" href="/css/styles.css">

  <style>
    .page-wrap {
      max-width: 1100px;
      margin: 30px auto;
      padding: 20px;
    }

    .writing-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 18px;
      border: 1px solid #dbe3ef;
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.06);
    }

    .evidence-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }

    .evidence-pill {
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid #e5e7eb;
      font-weight: 700;
    }

    /* Student view: evidence metadata is still saved, but colours are hidden from students. */
    .pasted-content,
    .declared-content,
    .ai-content,
    .ai-generated-content,
    .ai-modified-content,
    .citation-marker,
    span[data-pasted="true"],
    span[data-declared="true"] {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      font-weight: inherit !important;
    }

    .view-toggle-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .view-toggle-row .button {
      min-width: 160px;
    }

    .student-hidden {
      display: none !important;
    }

    .composition-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .composition-box {
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 14px;
      background: #f9fafb;
      text-align: center;
    }

    .composition-box strong {
      display: block;
      font-size: 1.6rem;
      margin-bottom: 4px;
    }

    #riskIndicator {
      padding: 10px 14px;
      color: #ffffff;
      border-radius: 10px;
      display: inline-block;
      font-weight: 700;
      margin-top: 14px;
      background: #16a34a;
    }

    .editor-actions {
      margin-top: 18px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .editor-actions .button {
      min-width: 130px;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(15, 23, 42, 0.65);
      z-index: 9999;
      padding: 24px;
    }

    .modal-card {
      width: min(720px, 100%);
      max-height: 90vh;
      overflow-y: auto;
      background: #ffffff;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    }

    .modal-card label {
      display: block;
      font-weight: 700;
      margin-top: 14px;
      margin-bottom: 6px;
    }

    .modal-card input,
    .modal-card select,
    .modal-card textarea {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      font: inherit;
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 18px;
    }

    .footer {
      margin-top: 40px;
      padding: 20px;
      text-align: center;
      font-size: 13px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
      background: #f9fafb;
    }
  </style>
</head>

<body>
  <main class="page-wrap">
    <section class="writing-card">
      <h1><%= assignment.title %></h1>
      <p class="small">
        <strong><%= student.name %></strong> |
        <%= student.class_name %>
      </p>
      <a class="button secondary" href="/student/dashboard">Back to dashboard</a>
    </section>

    <section class="writing-card">
      <h2>Student view options</h2>
      <p class="small">
        Evidence colours are hidden in the student editor. Your teacher can still review paste, declaration and citation evidence after submission.
      </p>
      <div class="view-toggle-row">
        <% if (assignment.show_student_evidence) { %>
          <button id="toggleEvidenceView" class="button secondary" type="button">Show evidence guide</button>
        <% } %>
        <% if (assignment.show_student_composition) { %>
          <button id="toggleCompositionView" class="button secondary" type="button">Show composition</button>
        <% } %>
      </div>
    </section>

    <% if (assignment.show_student_evidence) { %>
      <section class="writing-card student-hidden" id="studentEvidencePanel">
        <h2>Student Writing Evidence Guide</h2>
        <p class="small">This guide explains the evidence categories. Colours are not shown in your writing area.</p>

        <div class="evidence-grid">
          <div class="evidence-pill">External pasted text</div>
          <div class="evidence-pill">Declared material</div>
          <div class="evidence-pill">AI generated / modified</div>
          <div class="evidence-pill">Citation / bibliography</div>
        </div>
      </section>
    <% } %>

    <% if (assignment.show_student_composition) { %>
    <section class="writing-card student-hidden" id="studentCompositionPanel">
      <h2>Composition</h2>

      <div class="small">
        Status: <span id="save-status">Loading...</span> |
        Words: <span id="word-count">0</span>
      </div>

      <div class="composition-grid">
        <div class="composition-box">
          <strong id="ownPercent">0%</strong>
          Own work
        </div>

        <div class="composition-box">
          <strong id="pastePercent">0%</strong>
          Paste
        </div>

        <div class="composition-box">
          <strong id="declaredPercent">0%</strong>
          Declared
        </div>
      </div>

      <div id="riskIndicator">Risk: Low</div>
    </section>
    <% } %>

    <section class="writing-card">
      <textarea id="editor"></textarea>

      <div class="editor-actions">
        <button id="saveBtn" class="button" type="button">Save</button>
        <button id="declareBtn" class="button warning" type="button">Declare</button>
        <button id="referenceBtn" class="button secondary" type="button">Reference</button>
        <button id="submitBtn" class="button success" type="button">Submit</button>
      </div>
    </section>
  </main>

  <div id="declarationModal" class="modal-backdrop">
    <div class="modal-card">
      <h2>Declare material</h2>

      <label>Declaration type</label>
      <select id="declarationType">
        <option value="pasted_research">Pasted research / notes</option>
        <option value="ai_generated">AI generated</option>
        <option value="ai_modified">AI modified</option>
        <option value="own_notes">Own notes</option>
        <option value="teacher_resource">Teacher resource</option>
      </select>

      <label>Text / excerpt</label>
      <textarea id="pastedText" rows="4"></textarea>

      <label>How did you use it?</label>
      <textarea id="declarationExplanation" rows="4"></textarea>

      <hr>

      <h3>Reference Details</h3>

      <label>Source type</label>
      <select id="sourceType">
        <option value="">Choose source type</option>
        <option value="website">Website</option>
        <option value="book">Book</option>
        <option value="article">Article</option>
        <option value="video">Video</option>
        <option value="ai_tool">AI tool</option>
        <option value="teacher_resource">Teacher resource</option>
      </select>

      <label>Author / Organisation</label>
      <input id="sourceAuthor" type="text">

      <label>Year</label>
      <input id="sourceYear" type="text">

      <label>Title</label>
      <input id="sourceTitle" type="text">

      <label>Publisher / Website</label>
      <input id="sourcePublisher" type="text">

      <label>URL</label>
      <input id="sourceUrl" type="url">

      <label>Accessed date</label>
      <input id="accessedDate" type="date">

      <div class="modal-actions">
        <button class="button secondary" type="button" id="cancelDeclarationBtn">Cancel</button>
        <button class="button" type="button" id="saveDeclarationBtn">Save declaration</button>
      </div>
    </div>
  </div>

  <script>
  window.APP_DATA = {
    submissionId: <%- JSON.stringify(submission.id) %>,
    sessionId: <%- JSON.stringify(typeof sessionId !== "undefined" ? sessionId : 0) %>,
    initialContent: <%- JSON.stringify(submission.renderedHtml || latestContent || submission.final_text || "") %>,
    studentScaffold: <%- JSON.stringify(assignment.student_scaffold || "") %>,
    serverComposition: <%- JSON.stringify(typeof composition !== "undefined" ? composition : {
      own_work_percent: 100,
      paste_percent: 0,
      ai_declared_percent: 0,
      confidence: "Low"
    }) %>,
    showStudentEvidence: <%- JSON.stringify(!!assignment.show_student_evidence) %>,
    showStudentComposition: <%- JSON.stringify(!!assignment.show_student_composition) %>
  };
</script>

  <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>
  <script src="/js/writing-editor.js"></script>

  <footer class="footer">
    <div>© <%= new Date().getFullYear() %> Trevor Elliott. All rights reserved.</div>
    <div style="margin-top:6px;">
      Student Evidence App is a teacher-developed educational tool.
      Not for redistribution, resale, or commercial use without permission.
    </div>
    <div style="margin-top:6px;">
      <a href="/about-compliance">Privacy, Compliance & Copyright</a>
    </div>
  </footer>
</body>
</html>