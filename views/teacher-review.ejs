<!DOCTYPE html>
<html>
<head>
  <title>Teacher Review</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <main class="container">
    <header class="row-between wrap">
      <div>
        <h1><%= submission.assignment_title %></h1>
        <p class="small"><strong>Student:</strong> <%= submission.student_name %> | <strong>Class:</strong> <%= submission.class_name %></p>
      </div>
      <a class="button-link auto-width" href="/teacher/dashboard">Back</a>
    </header>

    <section class="card">
      <h2>Estimated composition of submission</h2>
      <div class="composition-grid">
        <div class="composition-card">
          <div class="composition-label">Estimated own work</div>
          <div class="composition-value"><%= composition.ownPercent %>%</div>
        </div>
        <div class="composition-card">
          <div class="composition-label">Estimated copy and paste</div>
          <div class="composition-value"><%= composition.pastePercent %>%</div>
        </div>
        <div class="composition-card">
          <div class="composition-label">Declared AI-assisted</div>
          <div class="composition-value"><%= composition.aiPercent %>%</div>
        </div>
        <div class="composition-card">
          <div class="composition-label">Confidence</div>
          <div class="composition-value composition-small"><%= composition.confidence %></div>
        </div>
      </div>
      <p class="small top-gap">These percentages are estimates based on writing activity, paste events, and student declarations. They are not proof of authorship.</p>
    </section>

    <section class="card">
      <h2>Flags</h2>
      <% if (!flags.length) { %>
        <p>No flags generated for this submission.</p>
      <% } else { %>
        <ul class="flag-list">
          <% flags.forEach(flag => { %><li class="flag <%= flag.severity %>"><strong><%= flag.code %>:</strong> <%= flag.message %></li><% }) %>
        </ul>
      <% } %>
    </section>

    <section class="card">
      <h2>Email feedback to student</h2>
      <p><strong>Student email:</strong> <%= submission.student_email || 'No email found' %></p>

      <label for="good-notes">What you did well</label>
      <textarea id="good-notes" rows="4" placeholder="Add strengths here..."></textarea>

      <label for="bad-notes">What needs improvement</label>
      <textarea id="bad-notes" rows="4" placeholder="Add areas for improvement here..."></textarea>

      <label for="ugly-notes">Most important next step</label>
      <textarea id="ugly-notes" rows="4" placeholder="Add the main concern or next step here..."></textarea>

      <div class="row gap wrap" style="margin-top: 12px;">
        <button type="button" id="generate-ai-email-btn" class="auto-width">Generate AI Email Draft</button>
        <button type="button" id="create-email-btn" class="auto-width">Create Email to Student</button>
      </div>

      <label for="ai-email-draft" style="margin-top: 12px;">AI draft email</label>
      <textarea id="ai-email-draft" rows="12" placeholder="AI draft will appear here. You can edit it before creating the email."></textarea>

      <div class="row gap" style="margin-top: 12px;">
        <button type="button" id="create-email-from-ai-btn" class="auto-width">Create Email from AI Draft</button>
      </div>

      <p class="small">Use Generate AI Email Draft to draft a professional email based on the submission, flags, declarations, and your notes. The teacher still reviews the wording before sending.</p>
    </section>

    <section class="card">
      <h2>Final text</h2>
      <div class="rich-preview"><%- submission.final_text || "<p>No submission text.</p>" %></div>
      <details class="top-gap">
        <summary>View HTML source</summary>
        <pre class="final-text"><%= submission.final_text %></pre>
      </details>
    </section>

    <section class="card">
      <h2>Writing sessions</h2>
      <% sessions.forEach(s => { %>
        <div class="timeline-item">
          <p><strong>Started:</strong> <%= s.started_at %></p>
          <p><strong>Ended:</strong> <%= s.ended_at || 'Still open' %></p>
          <p><strong>Active seconds:</strong> <%= s.active_seconds %> | <strong>Idle seconds:</strong> <%= s.idle_seconds %></p>
        </div>
      <% }) %>
    </section>

    <section class="card">
      <h2>Editor events</h2>
      <% events.forEach(e => { %>
        <div class="timeline-item">
          <p><strong><%= e.event_type %></strong> — <%= e.created_at %></p>
          <pre><%= e.event_meta %></pre>
        </div>
      <% }) %>
    </section>

    <section class="card">
      <h2>Source declarations</h2>
      <% declarations.forEach(d => { %>
        <div class="timeline-item">
          <p><strong>Type:</strong> <%= d.declaration_type %></p>
          <p><strong>Tool:</strong> <%= d.tool_name || '-' %></p>
          <p><strong>Prompt:</strong> <%= d.prompt_text || '-' %></p>
          <p><strong>Explanation:</strong> <%= d.student_explanation || '-' %></p>
        </div>
      <% }) %>
    </section>

    <section class="card">
      <h2>Snapshots</h2>
      <% snapshots.forEach(s => { %>
        <div class="timeline-item">
          <p><strong>Saved:</strong> <%= s.saved_at %> | <strong>Words:</strong> <%= s.word_count %></p>
          <details>
            <summary>View snapshot</summary>
            <div class="rich-preview top-gap"><%- s.content %></div>
            <details class="top-gap">
              <summary>View HTML source</summary>
              <pre class="final-text"><%= s.content %></pre>
            </details>
          </details>
        </div>
      <% }) %>
    </section>
  </main>

  <script>
    const createEmailBtn = document.getElementById("create-email-btn");
    const generateAiEmailBtn = document.getElementById("generate-ai-email-btn");
    const createEmailFromAiBtn = document.getElementById("create-email-from-ai-btn");
    const aiEmailDraft = document.getElementById("ai-email-draft");

    function buildManualBody() {
      const studentName = <%- JSON.stringify(submission.student_name || "") %>;
      const assignmentTitle = <%- JSON.stringify(submission.assignment_title || "Your submission") %>;
      const good = document.getElementById("good-notes").value.trim();
      const bad = document.getElementById("bad-notes").value.trim();
      const ugly = document.getElementById("ugly-notes").value.trim();

      return `Hi ${studentName},

Thank you for submitting your work for "${assignmentTitle}".

What you did well:
${good || "-"}

What needs improvement:
${bad || "-"}

Most important next step:
${ugly || "-"}

Please use this feedback to improve your future work.

Regards,
Teacher`;
    }

    function openEmail(bodyText) {
      const studentEmail = <%- JSON.stringify(submission.student_email || "") %>;
      const assignmentTitle = <%- JSON.stringify(submission.assignment_title || "Your submission") %>;

      if (!studentEmail) {
        alert("This student does not have an email address saved.");
        return;
      }

      const subject = `Feedback on ${assignmentTitle}`;
      const mailto = `mailto:${encodeURIComponent(studentEmail)}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(bodyText)}`;
      window.location.href = mailto;
    }

    createEmailBtn?.addEventListener("click", () => {
      openEmail(buildManualBody());
    });

    generateAiEmailBtn?.addEventListener("click", async () => {
      const studentName = <%- JSON.stringify(submission.student_name || "") %>;
      const studentEmail = <%- JSON.stringify(submission.student_email || "") %>;
      const assignmentTitle = <%- JSON.stringify(submission.assignment_title || "") %>;
      const finalText = <%- JSON.stringify(submission.final_text || "") %>;
      const flags = <%- JSON.stringify(flags || []) %>;
      const declarations = <%- JSON.stringify(declarations || []) %>;
      const composition = <%- JSON.stringify(composition || {}) %>;

      const goodNotes = document.getElementById("good-notes")?.value.trim() || "";
      const badNotes = document.getElementById("bad-notes")?.value.trim() || "";
      const uglyNotes = document.getElementById("ugly-notes")?.value.trim() || "";

      aiEmailDraft.value = "Generating AI draft...";

      try {
        const res = await fetch("/api/ai/generate-feedback-email", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            studentName,
            studentEmail,
            assignmentTitle,
            finalText,
            flags,
            declarations,
            composition,
            goodNotes,
            badNotes,
            uglyNotes
          })
        });

        const data = await res.json();

        if (!data.ok) {
          aiEmailDraft.value = data.error || "Could not generate AI draft.";
          return;
        }

        aiEmailDraft.value = data.draft || "Could not generate AI draft.";
      } catch (err) {
        console.error(err);
        aiEmailDraft.value = "Could not generate AI draft.";
      }
    });

    createEmailFromAiBtn?.addEventListener("click", () => {
      const body = aiEmailDraft.value.trim() || buildManualBody();
      openEmail(body);
    });
  </script>
</body>
</html>
