<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teacher Review</title>

  <link rel="stylesheet" href="/css/styles.css">

  <style>
    body {
      background: #f4f6f8;
      font-family: Arial, sans-serif;
      color: #111827;
      margin: 0;
    }

    .review-page {
      max-width: 1250px;
      margin: 28px auto;
      padding: 20px;
    }

    .review-header,
    .review-card {
      background: #ffffff;
      border-radius: 18px;
      padding: 22px;
      margin-bottom: 18px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 6px 22px rgba(15, 23, 42, 0.07);
    }

    .review-header h1 {
      margin-top: 0;
    }

    .review-grid {
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 18px;
      align-items: start;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
    }

    .meta-box {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      padding: 12px;
      border-radius: 12px;
    }

    .composition-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
    }

    .metric {
      border-radius: 14px;
      padding: 14px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
    }

    .metric strong {
      display: block;
      font-size: 1.6rem;
      margin-bottom: 4px;
    }

    .flag {
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 10px;
      border: 1px solid #fcd34d;
      background: #fffbeb;
    }

    .flag.info {
      border-color: #93c5fd;
      background: #eff6ff;
    }

    .flag.warning {
      border-color: #f59e0b;
      background: #fff7ed;
    }

    .evidence-legend {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 10px;
      margin: 12px 0 18px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #f9fafb;
      padding: 8px 10px;
      border-radius: 10px;
      border: 1px solid #e5e7eb;
      font-size: 0.9rem;
    }

    .dot {
      width: 18px;
      height: 18px;
      border-radius: 5px;
      display: inline-block;
      flex: 0 0 auto;
    }

    .dot-paste { background: #fff3b0; border: 2px solid #f59e0b; }
    .dot-ai { background: #fee2e2; border: 2px solid #dc2626; }
    .dot-declared { background: #dcfce7; border: 2px solid #16a34a; }
    .dot-citation { background: #dcfce7; border: 2px solid #16a34a; }

    .evidence-document {
      background: #ffffff;
      border: 1px solid #d1d5db;
      border-radius: 14px;
      padding: 22px;
      line-height: 1.65;
      min-height: 280px;
      overflow-wrap: break-word;
    }

    .evidence-document .pasted-content,
    .evidence-document span[data-pasted="true"] {
      background: #fff3b0 !important;
      border-bottom: 2px solid #f59e0b !important;
      padding: 1px 3px;
      border-radius: 4px;
    }

    .evidence-document .ai-modified-content,
    .evidence-document .ai-generated-content {
      background: #fee2e2 !important;
      border-bottom: 2px solid #dc2626 !important;
      padding: 1px 3px;
      border-radius: 4px;
    }

    .evidence-document .declared-content,
    .evidence-document .evidence-declared {
      background: #dcfce7 !important;
      border-bottom: 2px solid #16a34a !important;
      padding: 1px 3px;
      border-radius: 4px;
    }

    .evidence-document .citation-marker {
      background: #dcfce7 !important;
      border: 1px solid #16a34a !important;
      border-radius: 4px;
      padding: 0 3px;
      font-weight: 700;
    }

    .declaration-card,
    .event-card,
    .snapshot-card {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 10px;
    }

    .declaration-card strong {
      color: #111827;
    }

    .small {
      color: #6b7280;
      font-size: 0.9rem;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }

    .email-box {
      width: 100%;
      min-height: 140px;
      padding: 12px;
      border-radius: 12px;
      border: 1px solid #cbd5e1;
      font-family: Arial, sans-serif;
      font-size: 0.95rem;
      box-sizing: border-box;
    }

    details summary {
      cursor: pointer;
      font-weight: 700;
      margin-bottom: 10px;
    }

    @media (max-width: 900px) {
      .review-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <main class="review-page">
    <section class="review-header">
      <h1>Teacher Review</h1>

      <div class="meta-grid">
        <div class="meta-box">
          <strong>Student</strong><br>
          <%= submission.student_name %>
        </div>

        <div class="meta-box">
          <strong>Email</strong><br>
          <%= submission.student_email || "—" %>
        </div>

        <div class="meta-box">
          <strong>Class</strong><br>
          <%= submission.class_name || "—" %>
        </div>

        <div class="meta-box">
          <strong>Assignment</strong><br>
          <%= submission.assignment_title || "—" %>
        </div>

        <div class="meta-box">
          <strong>Status</strong><br>
          <%= submission.status || "draft" %>
        </div>

        <div class="meta-box">
          <strong>Submitted</strong><br>
          <%= submission.submitted_at || "Not yet submitted" %>
        </div>
      </div>

      <div class="button-row">
        <a class="button secondary" href="/teacher/dashboard">Back to dashboard</a>
        <button class="button" type="button" id="generateFeedbackBtn">Generate AI feedback email</button>
      </div>
    </section>

    <section class="review-grid">
      <div>
        <section class="review-card">
          <h2>Student Writing Evidence</h2>

          <div class="evidence-legend">
            <div class="legend-item"><span class="dot dot-paste"></span> External pasted text</div>
            <div class="legend-item"><span class="dot dot-ai"></span> AI generated / modified</div>
            <div class="legend-item"><span class="dot dot-declared"></span> Declared material</div>
            <div class="legend-item"><span class="dot dot-citation"></span> Citation / bibliography</div>
          </div>

          <div class="evidence-document">
            <%- submission.renderedHtml || submission.final_text || "<p>No writing submitted.</p>" %>
          </div>
        </section>
        <p class="small" style="margin-top:20px; opacity:0.6;">
  Generated via Student Evidence App — © Trevor Elliott
</p>

        <section class="review-card">
          <h2>Declarations and References</h2>

          <% if (!declarations || !declarations.length) { %>
            <p>No declarations recorded.</p>
          <% } else { %>
            <% declarations.forEach((d, index) => { %>
              <div class="declaration-card">
                <p><strong>#<%= index + 1 %> Type:</strong> <%= d.declaration_type || "—" %></p>
                <p><strong>Explanation:</strong> <%= d.student_explanation || "—" %></p>

                <% if (d.original_text_excerpt) { %>
                  <p><strong>Excerpt:</strong> <span class="small"><%= d.original_text_excerpt %></span></p>
                <% } %>

                <% if (d.in_text_citation) { %>
                  <p><strong>In-text citation:</strong> <%= d.in_text_citation %></p>
                <% } %>

                <% if (d.bibliography_entry) { %>
                  <p><strong>Bibliography:</strong> <%= d.bibliography_entry %></p>
                <% } %>

                <p class="small">
                  Source:
                  <%= d.source_author || "—" %>,
                  <%= d.source_year || "n.d." %>,
                  <%= d.source_title || "Untitled" %>
                </p>

                <% if (d.source_url) { %>
                  <p class="small">URL: <%= d.source_url %></p>
                <% } %>
              </div>
            <% }) %>
          <% } %>
        </section>

        <section class="review-card">
          <details>
            <summary>Draft Snapshots</summary>

            <% if (!snapshots || !snapshots.length) { %>
              <p>No draft snapshots recorded.</p>
            <% } else { %>
              <% snapshots.slice().reverse().slice(0, 10).forEach((snap, index) => { %>
                <div class="snapshot-card">
                  <strong>Snapshot <%= index + 1 %></strong>
                  <p class="small">
                    Saved: <%= snap.saved_at || "—" %> |
                    Words: <%= snap.word_count || 0 %>
                  </p>
                </div>
              <% }) %>
            <% } %>
          </details>
        </section>
      </div>

      <aside>
        <section class="review-card">
          <h2>Writing Composition</h2>

          <div class="composition-grid">
            <div class="metric">
              <strong><%= composition.own_work_percent || 0 %>%</strong>
              Own work estimate
            </div>

            <div class="metric">
              <strong><%= composition.paste_percent || 0 %>%</strong>
              Paste estimate
            </div>

            <div class="metric">
              <strong><%= composition.ai_declared_percent || 0 %>%</strong>
              AI declared
            </div>

            <div class="metric">
              <strong><%= composition.confidence || "Low" %></strong>
              Confidence
            </div>
          </div>
        </section>

        <section class="review-card">
          <h2>Flags</h2>

          <% if (!flags || !flags.length) { %>
            <p>No flags raised.</p>
          <% } else { %>
            <% flags.forEach(flag => { %>
              <div class="flag <%= flag.severity || 'warning' %>">
                <strong><%= flag.flag_code || "Flag" %></strong>
                <p><%= flag.flag_message || flag %></p>
              </div>
            <% }) %>
          <% } %>
        </section>

        <section class="review-card">
          <h2>Teacher Action</h2>

          <% const hasFlags = flags && flags.length; %>
          <% const hasDeclarations = declarations && declarations.length; %>

          <% if (hasFlags && !hasDeclarations) { %>
            <p><strong>Recommended:</strong> Ask the student to explain pasted or externally supported material.</p>
          <% } else if (hasFlags && hasDeclarations) { %>
            <p><strong>Recommended:</strong> Review the declarations and compare them to highlighted evidence.</p>
          <% } else { %>
            <p><strong>Recommended:</strong> Evidence appears low risk. Provide normal writing feedback.</p>
          <% } %>
        </section>

        <section class="review-card">
          <h2>Editor Events</h2>

          <% if (!events || !events.length) { %>
            <p>No editor events recorded.</p>
          <% } else { %>
            <% events.slice().reverse().slice(0, 12).forEach((event, index) => { %>
              <div class="event-card">
                <strong><%= event.event_type %></strong>
                <p class="small"><%= event.created_at || "—" %></p>
              </div>
            <% }) %>
          <% } %>
        </section>
      </aside>
    </section>

    <section class="review-card">
      <h2>AI Feedback Email Draft</h2>

      <p class="small">
        Generate a short teacher-controlled feedback email. Review and edit before sending.
      </p>

      <div id="rubricVisual" class="rubric-visual" style="display:none;">
  <h3>Rubric / ISMG Alignment</h3>
  <div id="rubricSuggestedLevel" class="rubric-level"></div>
  <div id="rubricCriteria"></div>
</div>

      <textarea id="feedbackEmail" class="email-box"></textarea>

      <div class="button-row">
        <button class="button" type="button" id="copyFeedbackBtn">Copy email draft</button>
      </div>
    </section>
  </main>

  <script>
  const reviewData = {
    studentName: <%- JSON.stringify(submission.student_name || "") %>,
    studentEmail: <%- JSON.stringify(submission.student_email || "") %>,
    assignmentTitle: <%- JSON.stringify(submission.assignment_title || "") %>,
    submissionText: <%- JSON.stringify(submission.renderedHtml || submission.final_text || "") %>,
    rubricText: <%- JSON.stringify(submission.rubric_text || "") %>,
    composition: {
      own: <%= composition.own_work_percent || 0 %>,
      paste: <%= composition.paste_percent || 0 %>,
      ai: <%= composition.ai_declared_percent || 0 %>
    },
    flags: <%- JSON.stringify((flags || []).map(f => f.flag_code || f)) %>,
    declarations: <%- JSON.stringify(declarations || []) %>
  };

function renderRubricVisual(result) {
  const wrapper = document.getElementById("rubricVisual");
  const levelBox = document.getElementById("rubricSuggestedLevel");
  const criteriaBox = document.getElementById("rubricCriteria");

  if (!wrapper || !levelBox || !criteriaBox) return;

  wrapper.style.display = "block";
  levelBox.textContent = `Suggested level: ${result.suggestedLevel || "Teacher review required"}`;

  criteriaBox.innerHTML = "";

  (result.rubricAlignment || []).forEach(item => {
    const div = document.createElement("div");
    div.className = "rubric-criterion";

    div.innerHTML = `
      <strong>${item.criterion || "Criterion"}</strong>
      <p><b>Evidence:</b> ${item.evidence || "No specific evidence supplied."}</p>
      <p><b>Suggested:</b> ${item.suggestedLevel || "Teacher review required"}</p>
    `;

    criteriaBox.appendChild(div);
  });
}

  function renderAiFeedback(result) {
    renderRubricVisual(result);

    const box = document.getElementById("feedbackEmail");

    const strengths = (result.strengths || [])
      .map(item => `• ${item}`)
      .join("\n");

    const nextSteps = (result.nextSteps || [])
      .map(item => `• ${item}`)
      .join("\n");

    const alignment = (result.rubricAlignment || [])
      .map(item =>
        `• ${item.criterion}: ${item.evidence} (${item.suggestedLevel})`
      )
      .join("\n");

    box.value =
`Suggested level: ${result.suggestedLevel || "Teacher review required"}

Student-friendly feedback:
${result.studentFriendlyFeedback || ""}

Strengths:
${strengths}

Next steps:
${nextSteps}

Rubric / ISMG alignment:
${alignment}

Teacher notes:
${result.teacherNotes || ""}`;
  }

  async function generateFeedbackEmail() {
    const button = document.getElementById("generateFeedbackBtn");
    const box = document.getElementById("feedbackEmail");

    if (!reviewData.rubricText || !reviewData.rubricText.trim()) {
      alert("No rubric / ISMG text found for this assignment.");
      return;
    }

    button.disabled = true;
    button.textContent = "Assessing against rubric...";
    box.value = "Generating AI-assisted rubric feedback...";

    try {
      const response = await fetch("/api/ai-feedback", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(reviewData)
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || "AI feedback failed");
      }
      

      renderAiFeedback(result);
    } catch (err) {
      console.error(err);
      alert(err.message || "Could not generate feedback.");
      box.value = "";
    } finally {
      button.disabled = false;
      button.textContent = "Generate AI feedback email";
    }
  }

  document.getElementById("generateFeedbackBtn")?.addEventListener("click", generateFeedbackEmail);

  document.getElementById("copyFeedbackBtn")?.addEventListener("click", async () => {
    const text = document.getElementById("feedbackEmail").value;
    if (!text) return alert("Generate the feedback first.");
    await navigator.clipboard.writeText(text);
    alert("Feedback copied.");
  });
</script>
<footer style="
  margin-top:40px;
  padding:20px;
  text-align:center;
  font-size:13px;
  color:#6b7280;
  border-top:1px solid #e5e7eb;
  background:#f9fafb;
">
  <div>
    © <%= new Date().getFullYear() %> Trevor Elliott. All rights reserved.
  </div>

  <div style="margin-top:6px;">
    Student Evidence App is a teacher-developed educational tool.  
    Not for redistribution, resale, or commercial use without permission.
  </div>

  <div style="margin-top:6px;">
    <a href="/about-compliance">Privacy, Compliance & Copyright</a>
  </div>
</footer>
</body>
</html>