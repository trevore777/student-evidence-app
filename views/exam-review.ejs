<!DOCTYPE html>
<html>
<head>
  <title>Exam Builder</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f7fa;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 1000px;
      margin: 30px auto;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 24px;
      border-radius: 14px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.08);
      margin-bottom: 20px;
    }

    h1, h2 {
      margin-top: 0;
    }

    label {
      font-weight: bold;
      display: block;
      margin-top: 10px;
    }

    input, textarea {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid #ccc;
      margin-top: 6px;
      font-size: 14px;
      box-sizing: border-box;
    }

    textarea {
      min-height: 120px;
    }

    .row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .row input {
      flex: 1;
    }

    .button {
      margin-top: 15px;
      padding: 12px 16px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-weight: bold;
    }

    .primary {
      background: #2563eb;
      color: white;
    }

    .primary:hover {
      background: #1e4fd1;
    }

    .question-card {
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 12px;
      background: #fafafa;
    }

    .question-header {
      font-weight: bold;
      margin-bottom: 6px;
    }

    .answer-guide {
      margin-top: 10px;
      background: #eef2ff;
      padding: 10px;
      border-radius: 8px;
      font-size: 13px;
    }

    .submission {
      padding: 10px;
      border-bottom: 1px solid #ddd;
    }

    .empty {
      color: #777;
      font-style: italic;
    }
  </style>
</head>

<body>

<div class="container">

  <!-- EXAM HEADER -->
  <div class="card">
    <h1><%= exam.title %></h1>
    <p><%= exam.instructions %></p>
  </div>

  <!-- ADD QUESTION -->
  <div class="card">
    <h2>Add Question</h2>

    <form method="POST" action="/teacher/exams/<%= exam.id %>/questions/new">

      <label>Question Number</label>
      <input name="questionNumber" placeholder="e.g. 1, 1a, 2b" required />

      <label>Question</label>
      <textarea name="questionText" placeholder="Paste question here..." required></textarea>

      <label>Answer Guide / Marking Criteria</label>
      <textarea name="answerGuide" placeholder="Paste marking guide here..."></textarea>

      <div class="row">
        <div>
          <label>Marks</label>
          <input type="number" name="maxMarks" value="1" min="1" />
        </div>
      </div>

      <button class="button primary">+ Add Question</button>
    </form>
  </div>

  <!-- QUESTIONS LIST -->
  <div class="card">
    <h2>Questions</h2>

    <% if (!questions.length) { %>
      <p class="empty">No questions added yet.</p>
    <% } %>

    <% questions.forEach(q => { %>
      <div class="question-card">

        <div class="question-header">
          Q<%= q.question_number %> — <%= q.max_marks %> marks
        </div>

        <div><%= q.question_text %></div>

        <% if (q.answer_guide) { %>
          <div class="answer-guide">
            <strong>Marking Guide:</strong><br/>
            <%= q.answer_guide %>
          </div>
        <% } %>

      </div>
    <% }) %>
  </div>

  <!-- STUDENT SUBMISSIONS -->
  <div class="card">
    <h2>Student Submissions</h2>

    <% if (!submissions.length) { %>
      <p class="empty">No submissions yet.</p>
    <% } %>

    <% submissions.forEach(s => { %>
      <div class="submission">
        <strong><%= s.student_name %></strong> — <%= s.status %>

        <a href="/teacher/exams/<%= exam.id %>/submission/<%= s.id %>">
          Review
        </a>
      </div>
    <% }) %>
  </div>

</div>

</body>
</html>