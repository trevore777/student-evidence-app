<!DOCTYPE html>
<html>
<head>
  <title>Exam Review</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      margin: 0;
      color: #222;
    }

    .container {
      max-width: 1000px;
      margin: 30px auto;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 24px;
      border-radius: 14px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.08);
      margin-bottom: 18px;
    }

    .question-card {
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 14px;
      background: #fafafa;
    }

    .button {
      display: inline-block;
      padding: 12px 16px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: bold;
    }

    .secondary {
      background: #6b7280;
    }

    .ai-box {
      background: #eef2ff;
      border-radius: 10px;
      padding: 12px;
      margin-top: 12px;
    }

    .answer-box {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 12px;
      margin-top: 8px;
      white-space: pre-wrap;
    }

    .small {
      color: #666;
      font-size: 14px;
    }
  </style>
</head>

<body>
  <main class="container">

    <div class="card">
      <h1>Exam Review</h1>

      <p><strong>Student:</strong> <%= submission.student_name %></p>
      <p><strong>Exam:</strong> <%= submission.exam_title %></p>
      <p class="small">
        Status: <%= submission.status %> |
        Submitted: <%= submission.submitted_at || "Not submitted" %>
      </p>

      <a class="button secondary" href="/teacher/exams/<%= submission.exam_id %>">Back to Exam</a>
    </div>

    <div class="card">
      <h2>AI Marking</h2>

      <form method="POST" action="/teacher/exams/<%= submission.exam_id %>/submission/<%= submission.id %>/mark-ai">
        <button class="button" type="submit">AI Mark All Answers</button>
      </form>

      <p class="small">
        AI marks are suggestions only. The teacher should review and confirm final marks.
      </p>
    </div>

    <div class="card">
      <h2>Answers</h2>

      <% if (!answers || !answers.length) { %>
        <p>No answers found.</p>
      <% } %>

      <% (answers || []).forEach(a => { %>
        <div class="question-card">
          <h3>Q<%= a.question_number %> — <%= a.max_marks %> marks</h3>

          <p><strong>Question:</strong></p>
          <div class="answer-box"><%= a.question_text %></div>

          <p><strong>Student answer:</strong></p>
          <div class="answer-box"><%= a.student_answer || "No answer" %></div>

          <details style="margin-top:12px;">
            <summary><strong>Answer guide</strong></summary>
            <div class="answer-box"><%= a.answer_guide || "No answer guide provided" %></div>
          </details>

          <div class="ai-box">
            <p><strong>AI mark:</strong> <%= a.ai_mark ?? "Not marked" %> / <%= a.max_marks %></p>
            <p><strong>AI feedback:</strong> <%= a.ai_feedback || "—" %></p>
          </div>
        </div>
      <% }) %>
    </div>

  </main>
</body>
</html>