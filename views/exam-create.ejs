<!DOCTYPE html>
<html>
<head>
  <title>Create Exam</title>
</head>
<body>
  <h1>Create Exam Evidence Mode</h1>

  <% if (error) { %>
    <p style="color:red;"><%= error %></p>
  <% } %>

  <form method="POST" action="/teacher/exams/new">
    <label>Class</label><br>
    <select name="classId" required>
      <option value="">Select class</option>
      <% classes.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.class_name %></option>
      <% }) %>
    </select>

    <br><br>

    <label>Exam title</label><br>
    <input name="title" required style="width:100%;padding:10px;">

    <br><br>

    <label>Instructions</label><br>
    <textarea name="instructions" style="width:100%;height:120px;"></textarea>

    <br><br>

    <button>Create Exam</button>
  </form>
</body>
</html>