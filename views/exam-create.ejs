<!DOCTYPE html>
<html>
<head>
  <title>Create Exam</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f4f6f8; margin:0; }
    .container { max-width:900px; margin:30px auto; padding:20px; }
    .card { background:white; padding:24px; border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.08); }
    label { display:block; font-weight:bold; margin-top:14px; }
    input, select, textarea { width:100%; padding:12px; border:1px solid #ccc; border-radius:10px; box-sizing:border-box; font-size:16px; }
    textarea { min-height:220px; }
    .button { margin-top:18px; padding:12px 16px; background:#1d4ed8; color:white; border:0; border-radius:10px; cursor:pointer; font-size:16px; }
    .error { background:#fee2e2; color:#991b1b; padding:12px; border-radius:10px; }
  </style>
</head>
<body>
  <main class="container">
    <div class="card">
      <h1>Create Exam Evidence Mode</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form method="POST" action="/teacher/exams/new">
        <label>Class</label>
        <select name="classId" required>
          <option value="">Select class</option>
          <% (classes || []).forEach(c => { %>
            <option value="<%= c.id %>"><%= c.class_name %></option>
          <% }) %>
        </select>

        <label>Exam title</label>
        <input name="title" required />

        <label>Instructions</label>
        <textarea id="instructions-editor" name="instructions"></textarea>

<script src="/vendor/tinymce/tinymce.min.js"></script>
<script>
  tinymce.init({
    selector: "#instructions-editor",
    license_key: "gpl",
    height: 420,
    menubar: false,
    branding: false,
    plugins: "lists link table wordcount",
    toolbar:
      "undo redo | blocks | bold italic underline | bullist numlist | table | link | removeformat"
  });

  document.querySelector("form").addEventListener("submit", () => {
    tinymce.triggerSave();
  });
</script>

        <button class="button" type="submit">Create Exam</button>
      </form>
    </div>
  </main>
</body>
</html>